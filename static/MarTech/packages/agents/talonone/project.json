{
  "name": "play_c463_z26_rzy_mar_tech.talonone",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/agents/talonone/app",
  "release": {
    "version": {
      "versionActions": "@nxlv/python/src/release/version-actions"
    }
  },
  "tags": [],
  "metadata": {
    "generator": "py#project",
    "ports": [8083],
    "components": [
      {
        "generator": "py#strands-agent",
        "name": "agent",
        "port": 8083
      }
    ]
  },
  "targets": {
    "add": {
      "executor": "@nxlv/python:add",
      "options": {}
    },
    "build": {
      "dependsOn": ["lint", "compile", "test", "bundle", "docker"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/packages/agents/talonone"
      }
    },
    "compile": {
      "executor": "@nxlv/python:build",
      "outputs": ["{workspaceRoot}/dist/packages/agents/talonone/build"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/packages/agents/talonone/build",
        "publish": false,
        "lockedVersions": true,
        "bundleLocalDependencies": true
      },
      "cache": true
    },
    "format": {
      "executor": "@nxlv/python:ruff-format",
      "outputs": [],
      "options": {
        "filePatterns": ["app", "tests"]
      },
      "cache": true
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "",
        "verbose": false,
        "debug": false
      }
    },
    "lint": {
      "executor": "@nxlv/python:ruff-check",
      "outputs": [],
      "options": {
        "lintFilePatterns": ["app", "tests"]
      },
      "cache": true,
      "dependsOn": ["format"]
    },
    "lock": {
      "executor": "@nxlv/python:lock",
      "options": {
        "update": false
      }
    },
    "remove": {
      "executor": "@nxlv/python:remove",
      "options": {}
    },
    "sync": {
      "executor": "@nxlv/python:sync",
      "options": {}
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "outputs": [
        "{workspaceRoot}/reports/{projectRoot}/unittests",
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "uv run pytest tests/",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "update": {
      "executor": "@nxlv/python:update",
      "options": {}
    },
    "bundle-arm": {
      "cache": true,
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/agents/talonone/bundle-arm"],
      "options": {
        "commands": [
          "uv export --frozen --no-dev --no-editable --project packages/agents/talonone --package play_c463_z26_rzy_mar_tech.talonone -o dist/packages/agents/talonone/bundle-arm/requirements.txt",
          "uv pip install -n --no-deps --no-installer-metadata --no-compile-bytecode --python-platform aarch64-manylinux_2_28 --target dist/packages/agents/talonone/bundle-arm -r dist/packages/agents/talonone/bundle-arm/requirements.txt"
        ],
        "parallel": false
      },
      "dependsOn": ["compile"]
    },
    "bundle": {
      "dependsOn": ["bundle-arm"]
    },
    "agent-docker": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker build --platform linux/arm64 -t talonone-agent:latest packages/agents/talonone/app/agent --build-context workspace=."
        ],
        "parallel": false
      },
      "dependsOn": ["bundle-arm"]
    },
    "docker": {
      "dependsOn": ["agent-docker"]
    },
    "agent-serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["uv run fastapi dev app/agent/main.py --port 8083"],
        "cwd": "{projectRoot}"
      },
      "continuous": true
    }
  }
}
